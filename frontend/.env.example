# Copier vers .env.local pour le dev local (optionnel : des valeurs par défaut existent dans firebase.js)

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Chemin Realtime Database (défaut : capteurs)
# REACT_APP_FIREBASE_CAPTEURS_PATH=capteurs

# URL du backend Node (export CSV, défaut : http://localhost:3000)
# REACT_APP_API_URL=http://localhost:3000

# Volume plateau (mm) pour la scène 3D
# REACT_APP_BED_SIZE_X=220
# REACT_APP_BED_SIZE_Y=220
# REACT_APP_BED_SIZE_Z=250
