# Copier vers .env en local (ne pas committer .env)
PORT=3000

# MQTT (valeurs par défaut = broker public HiveMQ + topic imprimante)
# MQTT_BROKER_URL=mqtt://broker.hivemq.com
# MQTT_TOPIC=imprimante/ligne1/capteurs

# Firebase Admin — en prod (Railway), préférer une variable secrète JSON :
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_DATABASE_URL=https://iot-projet-97fb4-default-rtdb.europe-west1.firebasedatabase.app/

# MongoDB — optionnel ; sans MONGODB_URI, seul Firebase + MQTT restent actifs
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGODB_DB_NAME=iot_db
