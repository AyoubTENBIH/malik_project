# Copier vers .env en local (ne pas committer .env)
PORT=3000

# MQTT (broker public HiveMQ + topics capteurs / marlin)
# MQTT_BROKER_URL=mqtt://broker.hivemq.com
# MQTT_TOPIC_CAPTEURS=malik/imprimante/ligne1/capteurs
# MQTT_TOPIC_MARLIN=malik/imprimante/ligne1/marlin
# DATA_DIR=./data   (défaut : backend/data sur Railway)
# CORS_ORIGIN=*
MQTT_TOPIC_CAPTEURS=malik/imprimante/ligne1/capteurs
MQTT_TOPIC_MARLIN=malik/imprimante/ligne1/marlin
# Firebase Admin — obligatoire sur Railway (fichier firebaseKey.json non déployé) :
# Dans Railway → Variables : FIREBASE_SERVICE_ACCOUNT_JSON = collez tout le JSON du compte de service (une ligne).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Racine RTDB uniquement (sans /capteurs, sans / final) — le SDK Admin complète sinon :
# FIREBASE_DATABASE_URL=https://iot-projet-97fb4-default-rtdb.europe-west1.firebasedatabase.app

# MongoDB — optionnel ; sans MONGODB_URI, seul Firebase + MQTT restent actifs
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGODB_DB_NAME=iot_db
